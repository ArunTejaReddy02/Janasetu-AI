# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=JanaSetu-AI-Backend
API_PREFIX=api

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://janasetu:janasetu_password@localhost:5432/janasetu_db

# ─── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_MIN_32_CHAR_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── Google Gemini (PRIMARY — entity extraction + embeddings) ─
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash-lite
GEMINI_QUALITY_MODEL=gemini-2.5-flash

# ─── Embeddings ───────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ─── Clustering tuning ────────────────────────────────────────
SIMILARITY_THRESHOLD=0.80
DBSCAN_EPSILON=0.15
DBSCAN_MIN_SAMPLES=2
STT_CONFIDENCE_THRESHOLD=0.5

# ─── Google Cloud (STT + Translation — optional) ──────────────
# GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# ─── Twilio / WhatsApp ────────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Rate limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
