# ─── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=JanaSetu-AI-Backend
API_PREFIX=api
API_VERSION=v1

# ─── Database ─────────────────────────────────────────────────
# Example: postgresql://username:password@host:port/database_name?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require

# ─── JWT ──────────────────────────────────────────────────────
# Must be at least 32 characters long
JWT_SECRET=REPLACE_WITH_MIN_32_CHAR_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_MIN_32_CHAR_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# ─── Google Gemini (PRIMARY — entity extraction + embeddings) ─
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_QUALITY_MODEL=gemini-2.5-pro

# ─── Google Cloud (STT + Translation — optional) ──────────────
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-service-account.json

# ─── Bhashini (fallback STT/translation for low-resource Indian languages) ─
BHASHINI_API_KEY=your-bhashini-api-key
BHASHINI_USER_ID=your-bhashini-user-id
BHASHINI_INFERENCE_API_KEY=your-bhashini-inference-key

# ─── Sarvam AI (alternative STT/TTS) ──────────────────────────
SARVAM_API_KEY=your-sarvam-api-key

# ─── OpenAI (stub fallback only — not primary) ────────────────
OPENAI_API_KEY=sk-your-openai-api-key

# ─── Embeddings ───────────────────────────────────────────────
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# ─── Clustering / NLP Tuning ──────────────────────────────────
SIMILARITY_THRESHOLD=0.80
DBSCAN_EPSILON=0.15
DBSCAN_MIN_SAMPLES=2
STT_CONFIDENCE_THRESHOLD=0.50

# ─── Storage ──────────────────────────────────────────────────
STORAGE_PROVIDER=local
GCS_BUCKET_NAME=janasetu-submissions
GCS_BASE_URL=https://storage.googleapis.com
LOCAL_UPLOAD_PATH=./uploads

# ─── Notifications / SMTP ─────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@janasetu.ai

# ─── Rate limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── Swagger ──────────────────────────────────────────────────
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs

# ─── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

