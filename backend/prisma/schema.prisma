// ─────────────────────────────────────────────────────────────
// JanaSetu-AI — Prisma Schema
// ─────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────

enum Role {
  CITIZEN
  FIELD_AGENT
  WARD_OFFICER
  ANALYST
  ADMIN
  SUPER_ADMIN
}

enum SubmissionStatus {
  PENDING
  PROCESSING
  PROCESSED
  VERIFIED
  REJECTED
  DUPLICATE
  MANUAL_REVIEW_NEEDED
}

enum SubmissionChannel {
  WEB
  MOBILE
  WHATSAPP
  VOICE
  FIELD_AGENT
  IVR
}

enum SubmissionLanguage {
  ENGLISH
  HINDI
  TELUGU
  KANNADA
  TAMIL
  MARATHI
  BENGALI
  GUJARATI
  PUNJABI
  MALAYALAM
  ODIA
  ASSAMESE
  URDU
}

enum ProjectStatus {
  PROPOSED
  UNDER_REVIEW
  APPROVED
  IN_PROGRESS
  COMPLETED
  ON_HOLD
  CANCELLED
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  IN_APP
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  READ
}

enum HotspotSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── User ─────────────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String?   @unique
  phone             String?   @unique
  passwordHash      String?
  name              String
  role              Role      @default(CITIZEN)
  isActive          Boolean   @default(true)
  isEmailVerified   Boolean   @default(false)
  isPhoneVerified   Boolean   @default(false)
  preferredLanguage String    @default("ENGLISH")
  avatarUrl         String?
  wardId            String?
  constituencyId    String?
  metadata          Json?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  // Relations
  submissions     Submission[]
  projects        Project[]       @relation("ProjectCreator")
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([wardId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// ─── Submitter (PII table) ───────────────────────────────────

model Submitter {
  id                  String    @id @default(uuid())
  phoneHash           String?   @unique
  consentGiven        Boolean   @default(false)
  consentTimestamp    DateTime?
  deletionRequested   Boolean   @default(false)
  deletionRequestedAt DateTime?
  createdAt           DateTime  @default(now())
  submissions         Submission[]

  @@map("submitters")
}

// ─── AdminUnit (geographic hierarchy) ────────────────────────

model AdminUnit {
  id          String   @id @default(uuid())
  externalId  String   @unique
  name        String
  type        String
  parentId    String?
  centroidLat Float?
  centroidLng Float?
  geometry    Json?
  population  Int?
  metadata    Json?
  createdAt   DateTime @default(now())
  submissions Submission[]
  hotspots    Hotspot[]

  @@map("admin_units")
}

// ─── Submission ───────────────────────────────────────────────

model Submission {
  id              String             @id @default(uuid())
  submittedById   String?
  channel         SubmissionChannel  @default(WEB)
  status          SubmissionStatus   @default(PENDING)
  language        SubmissionLanguage @default(ENGLISH)

  // Content
  rawText         String?
  translatedText  String?
  audioUrl        String?
  imageUrls       String[]
  videoUrls       String[]

  // AI Processing
  category        String?
  subCategory     String?
  entities        Json?              // { location, issue_type, severity, ... }
  sentiment       String?
  urgencyScore    Float?             @default(0)
  embedding       Float[]            // vector embedding for similarity

  // Location
  latitude        Float?
  longitude       Float?
  wardId          String?
  constituencyId  String?
  address         String?
  locationName    String?

  // Processing
  processingLog   Json?
  duplicateOfId   String?
  clusterId       String?

  // Privacy / Consent (v3)
  submitterId     String?
  adminUnitId     String?
  sttConfidence   Float?
  consentState    String             @default("not_required")
  isDeleted       Boolean            @default(false)

  // Timestamps
  submittedAt     DateTime           @default(now())
  processedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  submittedBy     User?              @relation(fields: [submittedById], references: [id])
  submitter       Submitter?         @relation(fields: [submitterId], references: [id])
  adminUnit       AdminUnit?         @relation(fields: [adminUnitId], references: [id])
  hotspot         Hotspot?           @relation(fields: [clusterId], references: [id])
  recommendations Recommendation[]
  notifications   Notification[]

  @@index([status])
  @@index([channel])
  @@index([wardId])
  @@index([clusterId])
  @@index([submittedById])
  @@index([submittedAt])
  @@index([submitterId])
  @@index([adminUnitId])
  @@map("submissions")
}

// ─── Hotspot ──────────────────────────────────────────────────

model Hotspot {
  id              String          @id @default(uuid())
  category        String
  subCategory     String?
  severity        HotspotSeverity @default(MEDIUM)
  adminUnitId     String?
  wardId          String?
  constituencyId  String?
  latitude        Float?
  longitude       Float?
  radiusMeters    Float?          @default(500)
  title           String
  description     String?
  submissionCount Int             @default(0)
  affectedCount   Int             @default(0)
  priorityScore   Float           @default(0)
  tags            String[]
  metadata        Json?
  isResolved      Boolean         @default(false)
  resolvedAt      DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  submissions     Submission[]
  projects        Project[]
  recommendations Recommendation[]
  adminUnit       AdminUnit?      @relation(fields: [adminUnitId], references: [id])

  @@index([wardId])
  @@index([adminUnitId])
  @@index([category])
  @@index([severity])
  @@index([priorityScore])
  @@map("hotspots")
}

// ─── Recommendation ───────────────────────────────────────────

model Recommendation {
  id              String   @id @default(uuid())
  submissionId    String?
  hotspotId       String?
  projectId       String?

  // Scoring
  urgencyScore    Float    @default(0)
  impactScore     Float    @default(0)
  feasibilityScore Float   @default(0)
  costBenefitScore Float   @default(0)
  compositeScore  Float    @default(0)

  // Content
  title           String
  rationale       String?
  actionItems     Json?
  estimatedCost   Float?
  estimatedBenefit Float?
  timelineMonths  Int?
  weights         Json?   // snapshot of scoring weights used
  metadata        Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  submission      Submission? @relation(fields: [submissionId], references: [id])
  hotspot         Hotspot?    @relation(fields: [hotspotId], references: [id])
  project         Project?    @relation(fields: [projectId], references: [id])

  @@index([compositeScore])
  @@index([hotspotId])
  @@index([submissionId])
  @@map("recommendations")
}

// ─── Project ──────────────────────────────────────────────────

model Project {
  id              String        @id @default(uuid())
  hotspotId       String?
  createdById     String?
  title           String
  description     String?
  status          ProjectStatus @default(PROPOSED)
  category        String?
  wardId          String?
  constituencyId  String?
  estimatedCost   Float?
  actualCost      Float?
  priorityScore   Float         @default(0)
  startDate       DateTime?
  endDate         DateTime?
  completedAt     DateTime?
  tags            String[]
  attachments     String[]
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  hotspot         Hotspot?       @relation(fields: [hotspotId], references: [id])
  createdBy       User?          @relation("ProjectCreator", fields: [createdById], references: [id])
  recommendations Recommendation[]
  milestones      ProjectMilestone[]

  @@index([status])
  @@index([wardId])
  @@index([hotspotId])
  @@map("projects")
}

model ProjectMilestone {
  id          String    @id @default(uuid())
  projectId   String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_milestones")
}

// ─── Analytics ────────────────────────────────────────────────

model AnalyticsEvent {
  id            String   @id @default(uuid())
  eventType     String
  entityType    String?
  entityId      String?
  userId        String?
  wardId        String?
  constituencyId String?
  data          Json?
  timestamp     DateTime @default(now())

  @@index([eventType])
  @@index([entityType, entityId])
  @@index([wardId])
  @@index([timestamp])
  @@map("analytics_events")
}

model AnalyticsSnapshot {
  id             String   @id @default(uuid())
  snapshotType   String   // daily | weekly | monthly
  wardId         String?
  constituencyId String?
  period         String   // e.g., "2024-01", "2024-W03"
  data           Json
  generatedAt    DateTime @default(now())

  @@unique([snapshotType, wardId, period])
  @@index([snapshotType])
  @@index([wardId])
  @@map("analytics_snapshots")
}

// ─── Notification ─────────────────────────────────────────────

model Notification {
  id           String              @id @default(uuid())
  userId       String?
  submissionId String?
  channel      NotificationChannel @default(IN_APP)
  status       NotificationStatus  @default(PENDING)
  title        String
  body         String
  data         Json?
  scheduledAt  DateTime?
  sentAt       DateTime?
  deliveredAt  DateTime?
  readAt       DateTime?
  failureReason String?
  retryCount   Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // Relations
  user         User?        @relation(fields: [userId], references: [id])
  submission   Submission?  @relation(fields: [submissionId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([channel])
  @@map("notifications")
}

// ─── Settings ─────────────────────────────────────────────────

model Settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  category    String?
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@map("settings")
}

// ─── Audit Log ────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user       User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
